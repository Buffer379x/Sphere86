# =============================================================================
# Sphere86 Environment Configuration
# =============================================================================
# NOTE: Foundational settings for bootstrapping the system.
# All application-level settings (86Box, Quotas, Network, LDAP, Logging)
# are now managed via the dashboard UI.
# =============================================================================

# --- Server Identity ---
APP_SECRET_KEY=change_this_to_a_long_random_secret_key_in_production

# --- User / Group (non-root execution) ---
PUID=1000
PGID=1000
TZ=Europe/Berlin

# --- Data Directory (inside container this is always /data) ---
DATA_PATH=./data

# --- Image Library (optional, mounted read-only at /library inside containers) ---
LIBRARY_PATH=./library

# --- Initial Admin Setup ---
# Set to "true" to enable multi-user auth. "false" = open access
USER_MANAGEMENT=true
# Credentials used on first boot if USER_MANAGEMENT=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_EMAIL=admin@example.com

# --- Networking ---
# Port exposed on the host for HTTP
WEB_PORT=80
# Port exposed on the host for HTTPS (only used when SSL_CERTS_DIR is set)
HTTPS_PORT=443

# --- Web (nginx) upstream to the engine container ---
# Hostname (Docker DNS) or IPv4/IPv6 — nginx proxy targets ENGINE_HOST:8000 and :8001
#ENGINE_HOST=engine

# --- SSL / TLS (optional) ---
#SERVER_NAME=example.com
#SSL_CERTS_DIR=/etc/letsencrypt/live/example.com

# --- JWT ---
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Internal service URLs (used by backend to talk to runner) ---
# Runner is hosted inside the `engine` container (port 8001), so localhost is correct here.
RUNNER_URL=http://localhost:8001
