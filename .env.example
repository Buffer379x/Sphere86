# =============================================================================
# 86Web Environment Configuration
# =============================================================================

# --- Server Identity ---
APP_NAME=86Web
APP_SECRET_KEY=change_this_to_a_long_random_secret_key_in_production
APP_HOST=0.0.0.0
APP_PORT=8000

# --- User / Group (non-root execution) ---
PUID=1000
PGID=1000

# --- Data Directory (inside container this is always /data) ---
# Host path to the single data volume (creates vms/, roms/, config/, cache/ inside)
DATA_PATH=./data

# --- Image Library (optional, mounted read-only at /library inside containers) ---
# Point this at a directory of floppy/CD-ROM images on the host. 86Box VMs get a
# 'library' symlink in their media dir so they can browse it natively. Leave
# unset to use the default ./library subdirectory.
LIBRARY_PATH=./library

# --- User Management ---
# Set to "true" to enable multi-user auth. "false" = open access
USER_MANAGEMENT=true

# Admin credentials (used on first boot if USER_MANAGEMENT=true)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_EMAIL=admin@example.com

# --- LDAP (optional, only used if USER_MANAGEMENT=true) ---
LDAP_ENABLED=false
LDAP_SERVER=ldap://ldap.example.com
LDAP_PORT=389
LDAP_BASE_DN=dc=example,dc=com
LDAP_BIND_DN=cn=readonly,dc=example,dc=com
LDAP_BIND_PASSWORD=ldappassword
LDAP_USER_FILTER=(objectClass=person)
LDAP_GROUP_DN=cn=86web-users,ou=groups,dc=example,dc=com
LDAP_USERNAME_ATTR=uid
LDAP_EMAIL_ATTR=mail
LDAP_TLS=false

# --- 86Box ---
# Leave blank to always fetch latest from GitHub releases
BOX86_VERSION=
# Architecture for Linux 86Box binary (x86_64 or aarch64)
BOX86_ARCH=x86_64

# --- Networking ---
# Port exposed on the host for HTTP
WEB_PORT=80
# Port exposed on the host for HTTPS (only used when SSL_CERTS_DIR is set)
HTTPS_PORT=443

# --- SSL / TLS (optional) ---
# Hostname nginx will answer on (server_name directive).
# Leave unset or blank to accept any hostname (_).
#SERVER_NAME=example.com

# Host directory containing fullchain.pem and privkey.pem.
# When set and both files exist, nginx serves HTTPS and redirects HTTP → HTTPS.
# Leave unset to serve plain HTTP.
#SSL_CERTS_DIR=/etc/letsencrypt/live/example.com

# Base VNC port (each VM gets BASE_VNC_PORT + slot)
BASE_VNC_PORT=5900
# Base WebSocket port for noVNC
BASE_WS_PORT=6900
# Max concurrent running VMs (VNC slot limit)
MAX_CONCURRENT_VMS=50
# Hard cap on simultaneously running VMs (86Box emulation is CPU-heavy).
# Use GET /api/system/recommended-vm-limit (admin) to get a suggested value.
ACTIVE_VM_LIMIT=5

# --- Default User Quotas ---
DEFAULT_MAX_VMS=10
DEFAULT_MAX_STORAGE_GB=100

# --- JWT ---
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Internal service URLs (used by backend to talk to runner) ---
RUNNER_URL=http://runner:8001

# --- Logging ---
LOG_LEVEL=info

# --- VM Auto-Shutdown ---
# Automatically stop VMs that have been running longer than this many minutes.
# 0 = disabled (VMs run until manually stopped).
VM_AUTO_SHUTDOWN_MINUTES=0

# --- Audio streaming ---
# Browser-side audio buffer in seconds. Lower = less latency, higher = smoother.
# Requires rebuilding the web container after changing.
AUDIO_BUFFER_SECS=0.4
